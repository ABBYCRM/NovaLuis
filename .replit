modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nova: OpenClaw Gateway"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nova: Poll Events"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nova: Scratchpad Daemon"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nova: Deep Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nova: Social Media Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nova: Work Tree Worker"

[[workflows.workflow]]
name = "Nova: OpenClaw Gateway"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mkdir -p /home/runner/workspace/.nova-data/workspace && node_modules/.bin/openclaw gateway --port 18789"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Nova: Poll Events"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "OPENCLAW_STATE_DIR=/home/runner/workspace/.nova-data OPENCLAW_LOG_DIR=/tmp/openclaw node scripts/poll-events.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Nova: Scratchpad Daemon"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/scratchpad-daemon.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Nova: Deep Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "OPENCLAW_STATE_DIR=/home/runner/workspace/.nova-data node scripts/deep-worker.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Nova: Social Media Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/social-media-worker.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Nova: Work Tree Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "OPENCLAW_STATE_DIR=/home/runner/workspace/.nova-data node scripts/work-tree-worker.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/nova run test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 18131
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

