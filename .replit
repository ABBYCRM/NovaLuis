modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BOS OMEGA: Poll Events"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BOS OMEGA: Deep Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BOS OMEGA: Scratchpad Daemon"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BOS OMEGA: Work Tree Worker"

[[workflows.workflow]]
name = "BOS OMEGA: Poll Events"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "OPENCLAW_STATE_DIR=/home/runner/workspace/.nova-data OPENCLAW_LOG_DIR=/tmp/openclaw NOVA_WORKSPACE=/home/runner/workspace node scripts/poll-events.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "BOS OMEGA: Deep Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && OPENCLAW_STATE_DIR=/home/runner/workspace/.nova-data node scripts/deep-worker.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "BOS OMEGA: Scratchpad Daemon"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && node scripts/scratchpad-daemon.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && pnpm --filter @workspace/nova run test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "BOS OMEGA: Work Tree Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && node scripts/work-tree-worker.mjs"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 18131
externalPort = 3000

[nix]
channel = "stable-25_05"

# All secrets must be configured through Replit Secrets or the deployment
# platform environment. Dangerous host execution is disabled by default; set
# SUPER_NOVA_EXEC=1 only in an authenticated, isolated worker environment.
[userenv]

[userenv.shared]
SUPER_NOVA_EXEC = "0"
