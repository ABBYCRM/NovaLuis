{
  "name": "workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.11 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||'';if(!ua.startsWith('pnpm/')){console.error('Use pnpm instead of npm or yarn');process.exit(1)}\"",
    "typecheck:libs": "tsc --build",
    "typecheck:workspaces": "pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "typecheck": "pnpm run typecheck:libs && pnpm run typecheck:workspaces",
    "test:vector-memory": "pnpm exec tsx artifacts/api-server/src/lib/vector-memory.self-test.ts",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "build": "pnpm run typecheck && pnpm run build:api",
    "start": "node --enable-source-maps ./artifacts/api-server/dist/index.mjs",
    "start:api": "pnpm --filter @workspace/api-server run start",
    "start:skills": "node server.js"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
