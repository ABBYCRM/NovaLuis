{
  "schemaVersion": 1,
  "configRevision": 2,
  "autonomyEnabled": true,
  "enforcementMode": "FAIL_CLOSED",
  "timezone": "UTC",
  "dailyAutonomousRunCap": 60,
  "hourlyAutonomousRunCap": 12,
  "burstWindowMinutes": 10,
  "burstAutonomousRunCap": 3,
  "minimumSecondsBetweenAutonomousRuns": 60,
  "maximumConcurrentAutonomousRuns": 1,
  "maximumRunDurationSeconds": 1800,
  "maximumToolCallsPerRun": 100,
  "maximumCorrectionLoopsPerRun": 10,
  "maximumRepeatedIdenticalFailures": 3,
  "maximumEstimatedCostPerRunUsd": 5,
  "maximumEstimatedDailyCostUsd": 100,
  "maximumExternalApiCallsPerRun": 100,
  "maximumRepositoryWritesPerRun": 100,
  "maximumDeploymentAttemptsPerRun": 3,
  "maximumTasksPerHeartbeat": 1,
  "maximumHeartbeatDurationMinutes": 10,
  "maximumPaidSpendUsdPerHeartbeat": 0,
  "allowProductionDeploy": false,
  "allowProductionRestart": false,
  "allowDestructiveActions": false,
  "allowSecretRotation": false,
  "allowProtectedBranchPush": false,
  "allowExternalMessages": false,
  "failClosedOnMissingOrInvalidGovernance": true,
  "runCounterReset": "UTC_MIDNIGHT",
  "audit": {
    "enabled": true,
    "format": "JSONL",
    "redactSecrets": true,
    "stateDirectory": ".nova-data",
    "retentionDays": 90
  },
  "requiredRuntimeChecks": [
    "CONFIG_VALID",
    "AUTONOMY_ENABLED",
    "STATE_STORE_WRITABLE",
    "NO_ACTIVE_RUN_LEASE",
    "DAILY_CAP_AVAILABLE",
    "HOURLY_CAP_AVAILABLE",
    "BURST_CAP_AVAILABLE",
    "RESOURCE_BUDGET_AVAILABLE"
  ],
  "_description": "Machine-readable BOS OMEGA autonomy policy. Only controls implemented by the poller and Work Tree worker belong here. Missing, malformed, unsupported, or invalid governance disables new autonomous execution. Secrets and mutable counters must never be stored in this file."
}
